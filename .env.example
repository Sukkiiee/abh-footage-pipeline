# --- Google OAuth (Drive) ---
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
# Authorized redirect URI must be: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Groq (Whisper transcription, free tier) ---
# Groq hosts open-source Whisper models on their own hardware with a free,
# rate-limited tier. Get a key at https://console.groq.com/keys.
GROQ_API_KEY=
# Optional override; defaults to whisper-large-v3-turbo (fast + free-tier friendly).
# GROQ_WHISPER_MODEL=whisper-large-v3

# --- Narrative + short-form generation LLM ---
# Defaults to Groq (free tier, reuses GROQ_API_KEY above with a Llama model)
# so the whole pipeline runs at zero cost. Switch to Claude later by setting
# LLM_PROVIDER=anthropic and ANTHROPIC_API_KEY -- no code changes needed.
LLM_PROVIDER=groq
# GROQ_NARRATIVE_MODEL=llama-3.3-70b-versatile
# GROQ_SHORTFORM_MODEL=llama-3.3-70b-versatile

# --- Anthropic (only used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_NARRATIVE_MODEL=claude-opus-4-8
# ANTHROPIC_SHORTFORM_MODEL=claude-sonnet-4-6

# --- Session cookie encryption ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- App URL ---
# Required in production if not on Vercel (Vercel auto-fills VERCEL_URL).
# Locally, defaults to http://localhost:3000 if unset.
APP_URL=http://localhost:3000

# --- Optional: FCPXML local media path default ---
# Where the editor's machine is expected to have the source file when they
# open the .fcpxml. Editable per-run in the UI; this is only the fallback.
DEFAULT_LOCAL_MEDIA_DIR=/Users/Shared/ABH_Footage

# --- Optional: source file size safety cap ---
# Videos larger than this (in GB) are rejected before download. This exists
# to guard against exceeding Vercel's /tmp (ephemeral storage) limit on a
# deployed instance -- check your plan's current documented limit before
# raising it there. Running locally via `npm run dev` writes to your real
# disk, so it's much less of a concern; default is generous for local use.
# MAX_SOURCE_FILE_GB=10
