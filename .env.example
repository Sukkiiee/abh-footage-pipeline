# --- Google OAuth (Drive) ---
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
# Authorized redirect URI must be: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Groq (Whisper transcription, free tier) ---
# Groq hosts open-source Whisper models on their own hardware with a free,
# rate-limited tier. Get a key at https://console.groq.com/keys.
GROQ_API_KEY=
# Optional override; defaults to whisper-large-v3-turbo (fast + free-tier friendly).
# GROQ_WHISPER_MODEL=whisper-large-v3

# --- Narrative + short-form generation LLM ---
# Three modes:
#   groq     - free tier only. Long videos get automatically split into
#              smaller pieces to stay under Groq's rate limits (slower, but
#              still free). Requires nothing beyond GROQ_API_KEY above.
#   anthropic - always uses Claude. Requires ANTHROPIC_API_KEY. Real cost per
#              run (~$0.10-0.45 depending on video length) -- see
#              ANTHROPIC_DAILY_SPEND_CAP_USD below for a safety net.
#   auto     - tries Groq first (free); only if a video is too large for
#              Groq's limits, asks the user (in the UI, mid-run) to approve
#              the estimated Anthropic cost before ever spending anything.
#              Declining keeps it on Groq's free chunked path. This is also
#              overridable per run from the UI regardless of this default.
LLM_PROVIDER=groq
# GROQ_NARRATIVE_MODEL=llama-3.3-70b-versatile
# GROQ_SHORTFORM_MODEL=llama-3.3-70b-versatile

# --- Anthropic (only used when LLM_PROVIDER=anthropic, LLM_PROVIDER=auto, or a per-run "Anthropic" choice in the UI) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_NARRATIVE_MODEL=claude-opus-4-8
# ANTHROPIC_SHORTFORM_MODEL=claude-sonnet-4-6

# --- Optional: hard daily/monthly caps on real Anthropic spend (USD) ---
# Enforced right before every single Anthropic call, no matter how it was
# reached (explicit "Anthropic only" choice, or an approved Auto-mode
# switch) -- the actual safety net against a runaway bill if other people
# are also testing the app. Whichever cap is hit first blocks further
# Anthropic use (falls back to Groq) until ANTHROPIC_ADMIN_CODE is
# provided. Tracked in a local .anthropic-usage.json file (gitignored).
# Defaults: daily $5, monthly $5.
# ANTHROPIC_DAILY_SPEND_CAP_USD=5
# ANTHROPIC_MONTHLY_SPEND_CAP_USD=5

# --- Optional: dev-only override for the spend caps above ---
# A secret only you (the dev) should know. Once a cap is hit -- or if
# ANTHROPIC_ENABLED_FOR_OTHERS is off -- anyone trying to use Anthropic
# sees a field asking for this code; entering the correct one bypasses
# the cap for that call, entering nothing (or a wrong code) falls back to
# Groq instead. Leave unset and caps become hard blocks for everyone,
# including you, until raised directly in the environment.
# ANTHROPIC_ADMIN_CODE=

# --- Optional: master on/off switch for Anthropic access for others ---
# Defaults to enabled (still subject to the spend caps above). Set to
# 'false' to shut off Anthropic entirely for everyone except whoever has
# ANTHROPIC_ADMIN_CODE -- e.g. during a period of heavy testing by other
# people, or if you just want to keep the app Groq-only for a while.
# ANTHROPIC_ENABLED_FOR_OTHERS=true

# --- Session cookie encryption ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- App URL ---
# Required in production if not on Vercel or Render (both auto-fill their
# own URL env var, which the app already falls back to).
# Locally, defaults to http://localhost:3000 if unset.
APP_URL=http://localhost:3000

# --- Optional: FCPXML local media path default ---
# Where the editor's machine is expected to have the source file when they
# open the .fcpxml. Editable per-run in the UI; this is only the fallback.
DEFAULT_LOCAL_MEDIA_DIR=/Users/Shared/ABH_Footage

# --- Optional: source file size safety cap ---
# Videos larger than this (in GB) are rejected before download. This exists
# to guard against exceeding Vercel's /tmp (ephemeral storage) limit on a
# deployed instance -- check your plan's current documented limit before
# raising it there. Running locally via `npm run dev` writes to your real
# disk, so it's much less of a concern; default is generous for local use.
# MAX_SOURCE_FILE_GB=10

# --- Optional: reference material size cap ---
# Combined uploaded docs + transcribed reference videos are capped at this
# many characters per run (sent to the LLM on every run, both the narrative
# and short-form calls). Raise it if your reference material is getting
# silently truncated and you want more of it actually used.
# REFERENCE_MATERIAL_MAX_CHARS=60000

# --- Optional: local footage (read straight off this machine's disk) ---
# Off by default: exposes an endpoint that lists/reads files at a path you
# provide, which would be a real path-disclosure risk on a hosted deployment
# other people can reach. Only turn this on when running the app on your own
# computer as its only user (local dev, or a private local run) -- never on
# a shared hosted instance like Render/Vercel.
# ENABLE_LOCAL_FOOTAGE=true

# --- Optional: yt-dlp binary override ---
# Reference-video links (YouTube, Instagram, etc.) use yt-dlp, auto-downloaded
# and cached on first use. Set this to skip that and use a binary you've
# installed yourself instead, e.g. after `brew install yt-dlp`.
# YT_DLP_PATH=/opt/homebrew/bin/yt-dlp

# --- Optional: YouTube cookies for hosted deployments ---
# YouTube's bot detection challenges requests from datacenter/cloud IPs
# (Render, Vercel, etc.) much more than a typical home connection, and can
# refuse outright ("Sign in to confirm you're not a bot") without this.
# Fix: while logged into youtube.com in your own browser, export cookies
# with an extension like "Get cookies.txt LOCALLY", then paste the full
# file contents here (multi-line is fine). Treat this like a credential --
# it's your personal YouTube session.
# YT_DLP_COOKIES_CONTENT="# Netscape HTTP Cookie File
# .youtube.com	TRUE	/	TRUE	1999999999	NAME	value
# ..."
